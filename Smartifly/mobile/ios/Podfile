# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'SmartiflyApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Optional iOS VLC path for MKV playback.
  # Enable with: USE_IOS_VLC=1 pod install
  if ENV['USE_IOS_VLC'] == '1'
    Pod::UI.puts 'Enabling MobileVLCKit (USE_IOS_VLC=1)'.green
    pod 'MobileVLCKit', '~> 3.6'
  else
    Pod::UI.puts 'MobileVLCKit disabled (USE_IOS_VLC not set)'.yellow
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Patch for modern Xcode SDK compatibility.
    # Fixes "consteval" errors in fmt/glog and related C++ pods.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        unless config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'].include?('FMT_USE_CONSTEVAL=0')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FMT_USE_CONSTEVAL=0'
        end
        unless config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'].include?('FMT_STATIC_THOUSANDS_SEPARATOR=1')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FMT_STATIC_THOUSANDS_SEPARATOR=1'
        end
      end
    end
  end
end
