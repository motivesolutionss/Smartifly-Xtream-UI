# ==============================================================================
# SMARTIFLY XTREAM UI - VPS ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================
# Copy this file to a private path on the server and fill real values there.
# Do NOT commit real secrets to git.

# 1. DATABASE CONFIGURATION (Internal Docker)
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=xtream_db
MYSQL_USER=xtream_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# 2. BACKEND API CONFIGURATION (xtream-api)
PORT=5000
NODE_ENV=production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
DATABASE_URL=mysql://xtream_user:CHANGE_ME_STRONG_DB_PASSWORD@xtream-db:3306/xtream_db
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PRIVATE KEY-----"
FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS & Frontend URLs
CORS_ORIGINS=https://xtreamui.example.com,https://admin.xtreamui.example.com
FRONTEND_URL=https://xtreamui.example.com

# Email (SMTP / Brevo)
BREVO_API_KEY=CHANGE_ME_BREVO_API_KEY
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASS
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

# 3. FRONTEND CONFIGURATION (Build-time variables)
NEXT_PUBLIC_API_URL=https://api.xtreamui.example.com
